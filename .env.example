# Copy this file to .env and fill in your broker credentials.
# Do not commit your real .env.

# Feed selection: yfinance | angelone | dhan
PRICE_FEED=angelone

# Angel One SmartAPI credentials
ANGELONE_API_KEY=
ANGELONE_CLIENT_ID=
ANGELONE_PASSWORD=
ANGELONE_TOTP_SECRET=

# Optional websocket resilience tuning
ANGELONE_WS_STALE_SECS=3
ANGELONE_WS_RECONNECT_MIN_SECS=1
ANGELONE_WS_RECONNECT_MAX_SECS=10
ANGELONE_WS_FAILBACK_TICKS=3
ANGELONE_WS_FALLBACK_DWELL_SECS=15

# Dhan credentials (optional)
DHAN_ACCESS_TOKEN=
DHAN_CLIENT_ID=
